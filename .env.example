# Server settings
PORT=3000

# Database Configuration
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://sdr_admin:admin_secure_pass_2026@localhost:5432/lions_ai_sdr?sslmode=disable

# Redis Configuration
# Format: redis://[host]:[port]
REDIS_URL=redis://localhost:6379

# Google Gemini API Config
GEMINI_API_KEY=your_gemini_api_key_here

# Langfuse Observability Config
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# Apollo API Strategy
APOLLO_API_KEY=mock_key_enterprise_sdr
ALLOW_LIVE_APOLLO=false
APOLLO_SEARCH_LIMIT=5

# App Environment
APP_ENV=development
ALLOW_LIVE_OUTREACH=false

# Unipile Strategy Configurations
UNIPILE_ACCESS_TOKEN=mock_unipile_token_here
UNIPILE_API_URL=https://api1.unipile.com:13111
UNIPILE_ACCOUNT_ID=mock_unipile_account_id
UNIPILE_WEBHOOK_SECRET=your_webhook_signature_secret_here

# Smartlead Strategy Configurations
SMARTLEAD_API_KEY=mock_smartlead_api_key
SMARTLEAD_CAMPAIGN_ID=12345
SMARTLEAD_WEBHOOK_SECRET=your_smartlead_webhook_secret
SMARTLEAD_API_URL=https://server.smartlead.ai/api/v1

# Sequence Wait Duration (24 Hours in Milliseconds = 86400000)
# Set to 5000 (5 seconds) in development environments for rapid integration testing
LINKEDIN_FOLLOWUP_DELAY_MS=86400000
